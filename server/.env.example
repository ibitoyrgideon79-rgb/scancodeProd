# Copy this file to .env and fill real values locally.
# Do not commit .env. It is already ignored by Git.

SPRING_PROFILES_ACTIVE=docker
APP_AUTH_PUBLIC_BASE_URL=http://localhost:8082

POSTGRES_DB=scancodes
POSTGRES_USER=scancodes
POSTGRES_PASSWORD=scancodes_dev_password

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/scancodes
SPRING_DATASOURCE_USERNAME=scancodes
SPRING_DATASOURCE_PASSWORD=scancodes_dev_password

# ZeptoMail SMTP (https://www.zoho.com/zeptomail/)
ZEPTOMAIL_SMTP_HOST=smtp.zeptomail.com
ZEPTOMAIL_SMTP_PORT=587
ZEPTOMAIL_SMTP_USERNAME=emailapikey
ZEPTOMAIL_SMTP_PASSWORD=your_zeptomail_smtp_password
ZEPTOMAIL_FROM_ADDRESS=noreply@scancode.ng
ZEPTOMAIL_FROM_NAME=ScanCode

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
